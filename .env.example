# Copy to .env.local for `vercel dev`, OR set these in
# Vercel → Project → Settings → Environment Variables.
#
# Set ANY of these — each enables that provider's server-side key so users don't
# need to paste their own. Add more for better fallback coverage.
# Users can still add their own key in Settings for any provider you leave unset.

# OpenRouter — free models (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq — fast & free (https://console.groq.com/keys)
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini — free tier (https://aistudio.google.com/app/apikey)
# Also enables 🍌 Nano Banana image editing (gemini-2.5-flash-image) via /api/image
# GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cerebras — fast & free (https://cloud.cerebras.ai/)
# CEREBRAS_API_KEY=csk-xxxxxxxxxxxxxxxxxxxxxxxx
